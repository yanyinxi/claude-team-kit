{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["allowed", "forbidden"],
  "properties": {
    "allowed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Allowed path patterns for file operations"
    },
    "forbidden": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Forbidden path patterns for file operations"
    },
    "by_domain": {
      "type": "object",
      "description": "Domain-specific path overrides"
    }
  }
}
