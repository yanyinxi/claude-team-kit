{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["name", "severity", "pattern"],
    "properties": {
      "name": { "type": "string" },
      "severity": {
        "enum": ["Critical", "High", "Medium", "Low"],
        "description": "Severity level of the violation"
      },
      "pattern": {
        "type": "string",
        "description": "Regex pattern to detect the violation"
      },
      "message": {
        "type": "string",
        "description": "Human-readable error message"
      },
      "domains": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Applicable domains for this rule"
      }
    }
  }
}
