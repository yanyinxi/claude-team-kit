{
  "$schema": "https://claude.com/docs/claude-code/plugin-schema",
  "name": "claude-harness-kit",
  "version": "0.7.0",
  "schemaVersion": "1.0.0",
  "description": "Claude Harness Kit — Human steers, Agents execute. 多 Agent 协作、通用 Skills、持续进化。借鉴 OpenAI Harness Engineering 方法论。",
  "author": {
    "name": "Claude Harness Kit Team"
  },
  "license": "MIT",
  "homepage": "https://github.com/yanyinxi/claude-harness-kit",
  "tags": ["multi-agent", "harness", "collaboration", "skills", "evolution"],
  "compatibility": {
    "claudeCode": ">=2.1.0",
    "os": ["darwin", "linux", "win32"]
  },

  "profiles": {
    "minimal": {
      "description": "最小化安装 — 6 个核心 Agent + 4 Skill + 2 Rule + safety-hook",
      "agents": [
        "orchestrator", "backend-dev", "frontend-dev", "code-reviewer", "explore", "verifier"
      ],
      "skills": ["testing", "git-master", "code-quality", "debugging"],
      "rules": ["general.md", "security.md"],
      "hooks": ["safety-check.sh"],
      "size": "~2MB"
    },
    "core": {
      "description": "核心安装 — 15 个 Agent + 12 Skill + 4 Rule + 全部基础 Hook",
      "agents": [
        "orchestrator", "architect", "tech-lead", "product-manager",
        "backend-dev", "frontend-dev", "database-dev", "devops",
        "executor", "code-reviewer", "qa-tester", "test",
        "verifier", "explore", "security-auditor"
      ],
      "skills": [
        "requirement-analysis", "architecture-design", "task-distribution",
        "testing", "code-quality", "debugging", "git-master",
        "ship", "security-audit", "database-designer", "api-designer", "tdd"
      ],
      "rules": ["general.md", "collaboration.md", "security.md", "quality-gates.md"],
      "hooks": ["safety-check.sh", "quality-gate.sh", "collect_session.py", "collect-agent.py"],
      "size": "~5MB"
    },
    "full": {
      "description": "完整安装 — 22 个 Agent + 19 Skill + 6 Rule + evolve-daemon",
      "agents": "*",
      "skills": "*",
      "rules": "*",
      "hooks": "*",
      "size": "~12MB"
    }
  },

  "dependencies": {
    "optional": {
      "PyYAML": "用于 config.yaml 解析，不装则用内联默认配置（零破坏）"
    },
    "incompatible": []
  },

  "permissions": {
    "scripts": {
      "safety-check.sh": ["Bash"],
      "quality-gate.sh": ["Read"],
      "tdd-check.sh": ["Read"],
      "collect_session.py": ["Read", "Write"],
      "collect-agent.py": ["Read", "Write"],
      "collect-failure.py": ["Read", "Write"],
      "collect-skill.py": ["Read", "Write"],
      "extract-semantics.py": ["Read", "Write"]
    }
  },

  "onboarding": {
    "firstRun": {
      "step1": "运行 kit init 初始化项目",
      "step2": "kit mode default 确认执行模式",
      "step3": "编辑项目 CLAUDE.md 补充 TODO 项",
      "step4": "git commit 提交配置"
    },
    "bootstrapCommands": [
      "kit init .",
      "kit mode default",
      "kit status"
    ]
  }
}