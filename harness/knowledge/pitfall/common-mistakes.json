  "content": {
    "problem": "使用 open() 写入 JSON 时忘记指定 encoding='utf-8'",
    "symptom": "中文内容出现乱码",
    "solution": "始终使用 Path.write_text(json.dumps(...), encoding='utf-8')",
    "example_bad": "open('file.json', 'w').write(json.dumps(data))",
    "example_good": "Path('file.json').write_text(json.dumps(data, ensure_ascii=False), encoding='utf-8')"
  },
