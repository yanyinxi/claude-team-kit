# =============================================================================
# 自动进化系统配置文件
# =============================================================================
# 本文件控制自动进化系统的所有行为参数。
# 修改配置后无需重启，下次触发时自动生效。
#
# 配置说明：
#   - 顶层分为多个配置块，每个块控制不同功能模块
#   - 所有注释都使用 YAML 注释格式 (#)
#   - 布尔值：true/false
#   - 时间单位：秒、分钟、小时、天
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Claude API 配置
# -----------------------------------------------------------------------------
# 控制 LLM 调用的参数，包括分析、决策、提取等不同任务的模型选择和参数
claude_api:
  # -------------------------------------------------------------------------
  # 分析任务配置（analyzer.py）
  # -------------------------------------------------------------------------
  analyze_max_tokens: 4096
  # 分析结果的最大 token 数量
  # 建议值：2048-8192，根据分析复杂度调整
  # 值越大，能返回的分析结果越详细，但消耗更多 token

  analyze_model: claude-sonnet-4-6
  # 用于分析会话数据的模型
  # 推荐：claude-sonnet-4-6（性价比高）
  # 也可选择：claude-opus-4-7（更强大但更贵）

  analyze_temperature: 0.3
  # 分析任务的随机性（0.0-1.0）
  # 0.0 = 确定性输出，结果稳定一致
  # 0.3 = 适度随机，适合分析任务
  # 1.0 = 完全随机，适合创意任务

  # -------------------------------------------------------------------------
  # 决策任务配置（llm_decision.py）
  # -------------------------------------------------------------------------
  decide_max_tokens: 2048
  # 决策结果的最大 token 数量
  # 决策输出通常较短，2048 通常足够

  decide_model: claude-sonnet-4-6
  # 用于做决策的模型，通常与分析模型相同

  decide_temperature: 0.2
  # 决策任务的随机性
  # 建议值：0.1-0.3，决策需要相对稳定

  # -------------------------------------------------------------------------
  # 提取任务配置（从会话中提取关键信息）
  # -------------------------------------------------------------------------
  extract_max_tokens: 512
  # 提取任务的最大 token 数量
  # 提取通常只返回简短结果，512 足够

  extract_model: claude-haiku-4-5
  # 用于提取关键信息的模型
  # 使用 Haiku 是因为提取任务相对简单，节省成本

  extract_temperature: 0.1
  # 提取任务的随机性
  # 建议值：0.1，保持提取结果一致性

# -----------------------------------------------------------------------------
# 2. 守护进程配置
# -----------------------------------------------------------------------------
# 控制守护进程的运行模式和调度行为
daemon:
  # -------------------------------------------------------------------------
  # 运行模式
  # -------------------------------------------------------------------------
  mode: both
  # 守护进程的触发模式
  # 可选值：
  #   - "external" : 外部触发模式，由 cron/launchd 调用 daemon.py run
  #   - "internal" : 内置定时任务模式，daemon 进程内部自己定时触发
  #   - "both"     : 同时支持外部和内部触发（推荐）
  #
  # 推荐：
  #   - 简单使用：external + 外部 cron
  #   - 一键启动：internal 或 both

  # -------------------------------------------------------------------------
  # 内置调度器配置（仅当 mode 包含 "internal" 时生效）
  # -------------------------------------------------------------------------
  scheduler_interval: 30 minutes
  # 定时任务触发间隔
  # 格式：数字 + 单位
  # 支持的单位：
  #   - "seconds" / "s" : 秒
  #   - "minutes" / "m" : 分钟
  #   - "hours" / "h"   : 小时
  # 示例：
  #   - "30 minutes" : 每 30 分钟运行一次（推荐）
  #   - "1 hours"    : 每 1 小时运行一次
  #   - "2 hours"    : 每 2 小时运行一次
  # 注意：过于频繁的触发会增加 API 调用成本

  run_on_startup: false
  # 守护进程启动时是否立即运行一次分析
  # true  : 启动后立即检查并可能触发分析
  # false : 等待到下次定时时间才首次运行

  # -------------------------------------------------------------------------
  # 心跳检测配置
  # -------------------------------------------------------------------------
  heartbeat_check_minutes: 180
  # 心跳检测间隔（分钟）
  # 即使调度器正常运行，也会按此间隔检查是否需要紧急进化
  # 建议值：60-360 分钟（1-6 小时）
  # 用途：防止长时间未进化时自动触发一次
  # 例如：设为 180（3小时），如果超过 3 小时没有进化，会自动触发

  auto_start_on_install: true
  # 插件安装时是否自动启动调度器
  # true  : 安装插件后自动启动调度器
  # false : 需要手动启动

  # -------------------------------------------------------------------------
  # 其他配置
  # -------------------------------------------------------------------------
  extract_timeout_seconds: 5
  # 单次会话数据提取的超时时间（秒）
  # 如果单次提取超过这个时间，会被强制终止

  idle_trigger_minutes: 120
  # 空闲触发阈值（分钟）
  # 当积累的新会话数达到阈值时，即使未到定时时间也触发分析
  # 例如：设为 120，当积累 120 分钟的新会话后自动触发
  # 设为 0 表示禁用此功能

  schedule: '*/30 * * * *'
  # Cron 表达式（仅用于文档说明，外部触发时由 cron 配置决定）

# -----------------------------------------------------------------------------
# 3. 时间衰减配置
# -----------------------------------------------------------------------------
# 控制本能记录的置信度随时间衰减的行为
decay:
  half_life_days: 90
  # 置信度半衰期（天）
  # 含义：经过这么多天后，置信度会降低一半
  # 90 天后：confidence = original * 0.5
  # 180 天后：confidence = original * 0.25
  # 建议值：60-180 天，根据项目变化频率调整

  decay_floor: 0.1
  # 置信度衰减下限
  # 置信度最低不会低于此值，防止完全失效
  # 建议值：0.1-0.2

  max_confidence: 0.95
  # 置信度上限
  # 单条本能记录的最高置信度
  # 设为 0.95 而不是 1.0 表示系统保持一定的谦逊

  min_reinforcement: 3
  # 强化阈值
  # 当本能记录被验证通过（reinforcement_count）达到此值时，
  # 半衰期延长 50%

  reinforcement_bonus: 0.05
  # 每次验证通过后置信度的增量
  # 例如：原置信度 0.8，验证通过后变为 0.85

# -----------------------------------------------------------------------------
# 4. 决策引擎配置
# -----------------------------------------------------------------------------
# 控制 LLM 决策引擎的行为和阈值
decision:
  enabled: true
  # 是否启用决策引擎
  # true  : 启用，LLM 会分析数据并做出决策
  # false : 禁用，只记录数据不进行决策

  auto_apply_threshold: 0.8
  # 自动应用的置信度阈值
  # 当置信度 >= 此值且风险为低时，自动应用改动
  # 建议值：0.7-0.9
  # 越高越保守，越低越激进

  high_risk_threshold: 0.5
  # 高风险判断的置信度阈值
  # 当置信度 < 此值时，认为是高风险操作

  require_human_review:
  # 必须人工确认的操作类型
  # 当改动涉及以下关键词时，强制进入 propose 模式
  - security
  # 安全相关：权限、认证、加密等
  - permission
  # 权限相关：文件权限、访问控制等
  - new_target
  # 新目标：首次对某个 Agent/Skill 进行优化
  - multi_file
  # 多文件：改动涉及多个文件

  risk_rules:
    # 风险判断规则
    high_risk_patterns:
    # 高风险关键词（命中任一即判定为高风险）
    - permission
    # 权限相关
    - credential
    # 凭证相关
    - security
    # 安全相关
    - auth
    # 认证相关

    low_risk_patterns:
    # 低风险关键词（命中任一可考虑自动应用）
    - comment
    # 注释相关
    - format
    # 格式化相关
    - typo
    # 拼写错误
    - docs
    # 文档相关
    - example
    # 示例相关

# -----------------------------------------------------------------------------
# 5. 通知配置
# -----------------------------------------------------------------------------
# 控制进化系统的通知渠道
notification:
  enabled: false
  # 是否启用通知
  # true  : 启用通知
  # false : 禁用通知

  channels:
    # 通知渠道配置
    email:
      enabled: false
      # 是否启用邮件通知
      # true  : 启用
      # false : 禁用

      smtp_host: smtp.example.com
      # SMTP 服务器地址
      # 例如：smtp.gmail.com, smtp.qq.com

      smtp_port: 587
      # SMTP 服务器端口
      # 常用值：587（TLS）, 465（SSL）, 25（无加密）

      to_addresses:
      # 邮件接收者列表
      - admin@example.com
      # 可以添加多个邮箱地址

# -----------------------------------------------------------------------------
# 6. 观察期配置
# -----------------------------------------------------------------------------
# 控制改动应用后的观察期行为
observation:
  days: 7
  # 观察期时长（天）
  # 改动应用后，系统会观察这段时间内的指标变化
  # 建议值：3-14 天
  # 太短：可能无法发现长期问题
  # 太长：问题发现周期长，影响进化速度

  check_interval_hours: 24
  # 观察期内检查指标的时间间隔（小时）
  # 建议值：12-48 小时

  metrics:
    # 观察指标配置
    min_success_rate: 0.8
    # 最低成功率
    # 观察期内的成功率低于此值，触发回滚
    # 建议值：0.7-0.9

    max_correction_rate: 0.2
    # 最高纠正率
    # 纠正率超过此值，触发回滚
    # 建议值：0.15-0.3

    max_failure_rate_delta: 0.1
    # 失败率最大增幅
    # 失败率相比基准值上升超过此值，触发回滚
    # 建议值：0.05-0.2

# -----------------------------------------------------------------------------
# 7. 路径配置
# -----------------------------------------------------------------------------
# 控制各类文件的存储路径
paths:
  agents_dir: agents
  # Agent 定义文件目录
  # 包含：agents/*.md

  backups_dir: .claude/data/backups
  # 文件备份目录
  # 改动前会备份原文件到此目录

  data_dir: .claude/data
  # 数据文件目录
  # 包含：sessions.jsonl, agent_calls.jsonl, failures.jsonl 等

  instinct_dir: harness/instinct
  # 本能记录目录
  # 包含：instinct-record.json

  proposals_dir: .claude/proposals
  # 提案文件目录
  # 包含：.claude/proposals/*.md

  rules_dir: rules
  # 规则文件目录
  # 包含：rules/*.md

  skills_dir: skills
  # Skill 定义文件目录
  # 包含：skills/*/SKILL.md

# -----------------------------------------------------------------------------
# 8. 回滚配置
# -----------------------------------------------------------------------------
# 控制自动回滚的行为
rollback:
  auto_enabled: true
  # 是否启用自动回滚
  # true  : 观察期发现问题自动回滚
  # false : 不自动回滚，只通知

  observe_before_rollback_hours: 24
  # 回滚前的观察时间（小时）
  # 触发回滚条件后，会先观察这段时间确认问题
  # 建议值：12-48 小时

  triggers:
  # 触发回滚的条件
  # 满足任一条件即可触发
  - success_rate_decreased
  # 成功率下降
  - correction_rate_increased
  # 纠正率上升
  - failure_count_increased
  # 失败次数增加
  - user_feedback_negative
  # 用户反馈负面

# -----------------------------------------------------------------------------
# 9. 安全限制配置
# -----------------------------------------------------------------------------
# 控制系统的安全边界
safety:
  max_proposals_per_day: 3
  # 每天最大提案数
  # 防止短时间内产生过多改动
  # 建议值：1-10

  auto_close_days: 7
  # 未处理提案的自动关闭天数
  # 超过此时间未处理的提案会自动关闭
  # 建议值：3-14

  breaker:
    # 熔断器配置
    max_consecutive_rejects: 3
    # 同一目标连续被拒绝的最大次数
    # 超过后暂停对该目标的优化
    # 建议值：2-5

    pause_days: 30
    # 暂停天数
    # 熔断器触发后，暂停这么多天后重新尝试
    # 建议值：7-30

    max_rollbacks_per_week: 5
    # 每周最大回滚次数
    # 超过后暂停整个系统的自动优化
    # 建议值：3-10

# -----------------------------------------------------------------------------
# 10. 触发阈值配置
# -----------------------------------------------------------------------------
# 控制何时触发分析的阈值
thresholds:
  max_hours_since_last_analyze: 6
  # 距上次分析的最大时间间隔（小时）
  # 超过此时间自动触发分析
  # 建议值：1-24

  min_failure_count: 3
  # 单个会话的最小失败次数
  # 超过此值触发分析
  # 建议值：3-10

  min_failure_rate: 0.3
  # Agent 最小失败率阈值
  # 失败率超过此值触发分析
  # 建议值：0.3-0.7

  min_failure_type_count: 2
  # 同类型失败的最小次数
  # 同一类型的失败达到此数触发分析
  # 建议值：2-5

  min_new_sessions: 1
  # 最小新会话数
  # 积累这么多新会话后触发分析
  # 建议值：2-10

  min_same_pattern_corrections: 2
  # 同一模式被纠正的最小次数
  # 同一模式被纠正达到此数触发分析
  # 建议值：2-5

# -----------------------------------------------------------------------------
# 11. 数据验证配置
# -----------------------------------------------------------------------------
# 控制数据验证的行为
validation:
  enabled: true
  # 是否启用数据验证
  # true  : 启用，验证收集的数据
  # false : 禁用

  max_age_days: 30
  # 数据最大保存天数
  # 超过此时间的数据会被清理
  # 建议值：30-180

  quarantine_malformed: true
  # 是否隔离格式错误的数据
  # true  : 格式错误的数据移动到隔离区
  # false : 直接丢弃