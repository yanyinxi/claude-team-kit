{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub API — PR 操作、Issue 管理、代码搜索"
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-playwright"],
      "description": "Playwright — 浏览器自动化测试、截图、DOM 操作"
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "description": "文件系统 — 安全的文件读写、目录扫描"
    }
  },
  "autoEnable": {
    "github": false,
    "playwright": false,
    "filesystem": true
  },
  "description": "Claude Harness Kit MCP 配置模板 — kit init 时可选择性启用"
}