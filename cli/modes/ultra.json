{
  "description": "Ultrawork 模式 — 极限并行，3-5 个 Agent 同时工作",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/bin/safety-check.sh", "timeout": 5 }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/bin/quality-gate.sh", "timeout": 10 }]
      },
      {
        "matcher": "Agent",
        "hooks": [{ "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/bin/collect-agent.py", "timeout": 5 }]
      }
    ],
    "Stop": [
      {
        "matcher": "Stop",
        "hooks": [{ "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/bin/collect-session.py", "timeout": 10 }]
      }
    ]
  }
}
